datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  analyticsEvents AnalyticsEvent[]
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]
  kits      Kit[]
}

model Product {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  description      String?
  price            Int
  stock            Int      @default(0)
  isActive         Boolean  @default(true)
  imageUrl         String?
  batteryLife      Int?
  maxSpeed         Int?
  cameraResolution String?
  weight           Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  orderItems OrderItem[]
  kitItems   KitItem[]

  @@index([categoryId])
  @@index([isActive])
  @@index([price])
}

model Order {
  id             String      @id @default(cuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id])
  total          Int
  status         OrderStatus @default(PENDING)
  customerName   String
  customerEmail  String
  shippingAddress String?
  city           String?
  state          String?
  zipCode        String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  unitPrice Int

  @@index([orderId])
  @@index([productId])
}

model Kit {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  price       Int
  imageUrl    String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])

  items KitItem[]

  @@index([categoryId])
}

model KitItem {
  id        String   @id @default(cuid())
  kitId     String
  kit       Kit     @relation(fields: [kitId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)

  @@index([kitId])
  @@index([productId])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
}

