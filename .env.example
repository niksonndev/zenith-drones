# =============================================================================
# Zenith Drones – variáveis de ambiente
# Copie para .env.local e preencha os valores.
# =============================================================================

# --- Sanity (obrigatório para app e Studio em /studio) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# Opcional; default no código: 2024-01-01
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Token para escrita/API server-side (opcional para só leitura pública)
# SANITY_API_TOKEN=

# --- NextAuth (recomendado: evita warning em dev e é obrigatório em produção) ---
AUTH_SECRET=

# --- Stripe (obrigatório para checkout) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# --- Opcional: provedores de login (ex.: Google) ---
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
